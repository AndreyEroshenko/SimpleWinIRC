<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleWinIRC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SimpleWinIRC"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SimpleWinIRC">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" MinWidth="320">
            <TextBlock Text="Connect to IRC" Style="{StaticResource SubtitleTextBlockStyle}" />

            <TextBox x:Name="ServerTextBox" Header="Server" PlaceholderText="irc.libera.chat" Text="irc.libera.chat" />

            <NumberBox x:Name="PortNumberBox" Header="Port" Value="6697" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Compact" />

            <TextBox x:Name="NicknameTextBox" Header="Nickname" PlaceholderText="your_nick" />

            <CheckBox x:Name="UseSslCheckBox" Content="Use SSL/TLS" IsChecked="True" />

            <Button x:Name="ConnectButton" Content="Connect" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Click="ConnectButton_Click" />

            <TextBlock x:Name="StatusTextBlock" Text="Not connected." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Window>
